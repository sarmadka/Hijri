صنف صـندوق_مناسبة {
    @حقنة عرف مركب: مـركب؛

    عملية هذا~هيئ(مناسبة: مـناسبة) {
        // حساب يوم الأسبوع للمناسبة
        عرف يوم_اسبوع_المناسبة: نـص = احسب_يوم_الاسبوع(
            مناسبة.السنة_الميلادية،
            مناسبة.الشهر_الميلادي،
            مناسبة.اليوم_الميلادي
        )؛

        عرف نص_التاريخ_الهجري: نـص = نـص.املأ("%i %s %i هـ"،
            مناسبة.اليوم_الهجري،
            الأشهر_الهجرية(مناسبة.الشهر_الهجري - 1)،
            مناسبة.السنة_الهجرية
        )؛

        عرف نص_التاريخ_الميلادي: نـص = نـص.املأ("%i %s %i م"،
            مناسبة.اليوم_الميلادي،
            الأشهر_الميلادية(مناسبة.الشهر_الميلادي - 1)،
            مناسبة.السنة_الميلادية
        )؛

        عرف نص_الأيام_المتبقية: نـص؛
        إذا مناسبة.الأيام_المتبقية == 0 {
            نص_الأيام_المتبقية = "اليوم"؛
        } وإلا إذا مناسبة.الأيام_المتبقية == 1 {
            نص_الأيام_المتبقية = "غداً"؛
        } وإلا {
            نص_الأيام_المتبقية = نـص.املأ("بعد %i يوم"، مناسبة.الأيام_المتبقية)؛
        }

        هذا.المشهد = صـندوق().{
            الطراز.{
                الإظهار = إظـهار._مرن_؛
                النسق = نـسق._عمود_؛
                الحشوة = مـسافة4.بكسلات(15)؛
                الخلفية = خـلفية(لـون("ecf0f1"))؛
                نصف_قطر_الإطار = مـسافة4.بكسلات(8)؛
                الهامش = مـسافة4.بكسلات(0، 0، 10، 0)؛
                الفجوة = مـسافة.بكسلات(15)؛
                أدنى_عرض = مـسافة.بكسلات(260)؛
                أقصى_عرض = مـسافة.بكسلات(400)؛
                المرونة = مـرونة(1)؛
            }؛
            أضف_فروع({
                // صندوق الرأس: اسم المناسبة والزر
                صـندوق().{
                    الطراز.{
                        الإظهار = إظـهار._مرن_؛
                        النسق = نـسق._سطر_؛
                        ملء_السطر = مـلء_سطر._مسافة_بينية_؛
                        المحاذاة = مـحاذاة._وسط_؛
                        الهامش = مـسافة4.بكسلات(0، 0، 8، 0)؛
                    }؛
                    أضف_فروع({
                        // اسم المناسبة
                        كـتابة(مناسبة.الاسم).{
                            الطراز.{
                                لون_الخط = لـون("2c3e50")؛
                                حجم_الخط = مـسافة.بكسلات(18.0)؛
                                فئة_الخط = "TajawalBold"؛
                                سمك_الخط = 700؛
                                المرونة = مـرونة(1)؛
                            }
                        }،
                        // زر الأيقونة
                        صـورة().{
                            الرابط = نـص("/mosque-svgrepo-com.svg")؛
                            الطراز.{
                                العرض = مـسافة.بكسلات(24)؛
                                الطول = مـسافة.بكسلات(24)؛
                                المؤشر = مـؤشر._سبابة_؛
                            }
                            عند_الضغط.اربط(مغلفة (مناسبة: كقيمة)&(سند[ضـبيطة]، سند[صـحيح]) {
                                // إظهار نافذة أوقات الصلاة
                                المكداس_الرئيسي.أضف(
                                    نـافذة_أوقات_الصلاة(مناسبة.السنة_الهجرية، مناسبة.الشهر_الهجري، مناسبة.اليوم_الهجري),
                                    نـص("للأمام")
                                )؛
                            })؛
                        }
                    })؛
                }،
                // التواريخ والأيام المتبقية
                صـندوق().{
                    الطراز.{
                        الإظهار = إظـهار._مرن_؛
                        النسق = نـسق._سطر_؛
                        ملء_السطر = مـلء_سطر._مسافة_بينية_؛
                        الفجوة = مـسافة.بكسلات(15)؛
                    }؛
                    أضف_فروع({
                        كـتابة(نـص("📅 ") + نص_التاريخ_الهجري).{
                            الطراز.{
                                لون_الخط = لـون("34495e")؛
                                حجم_الخط = مـسافة.بكسلات(14.0)؛
                            }
                        }،
                        كـتابة(نـص("📅 ") + نص_التاريخ_الميلادي).{
                            الطراز.{
                                لون_الخط = لـون("34495e")؛
                                حجم_الخط = مـسافة.بكسلات(14.0)؛
                            }
                        }
                    })؛
                }،
                صـندوق().{
                    الطراز.{
                        الإظهار = إظـهار._مرن_؛
                        النسق = نـسق._سطر_؛
                        ملء_السطر = مـلء_سطر._مسافة_بينية_؛
                        الفجوة = مـسافة.بكسلات(15)؛
                    }؛
                    أضف_فروع({
                        كـتابة(يوم_اسبوع_المناسبة).{
                            الطراز.{
                                لون_الخط = لـون("34495e")؛
                                حجم_الخط = مـسافة.بكسلات(14.0)؛
                            }
                        }،
                        كـتابة(نـص("⏳ ") + نص_الأيام_المتبقية).{
                            الطراز.{
                                لون_الخط = لـون("27ae60")؛
                                حجم_الخط = مـسافة.بكسلات(14.0)؛
                                فئة_الخط = "TajawalBold"؛
                                سمك_الخط = 600؛
                            }
                        }
                    })؛
                }
            })؛
        }؛
    }

    عملية هذا_الصنف(مناسبة: مـناسبة): سـندنا[صـندوق_مناسبة] {
        أرجع سـندنا[صـندوق_مناسبة]().{ احجز()~هيئ(مناسبة) }؛
    }
}
